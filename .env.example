APP_ENV=local
APP_NAME=SprintMind AI
WEB_URL=http://localhost:3000
API_URL=http://localhost:8000

DATABASE_URL=postgresql+asyncpg://sprintmind:sprintmind@localhost:5432/sprintmind
REDIS_URL=redis://localhost:6379/0

JWT_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_TOKEN_MINUTES=20
JWT_REFRESH_TOKEN_DAYS=14
ENCRYPTION_KEY=replace-with-fernet-key

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=
ATLASSIAN_REDIRECT_URI=http://localhost:8000/api/v1/jira/callback
ATLASSIAN_SCOPES=read:jira-work write:jira-work read:jira-user offline_access

COOKIE_SECURE=false
COOKIE_DOMAIN=
CORS_ORIGINS=http://localhost:3000

MAX_UPLOAD_SIZE_MB=15
ALLOWED_UPLOAD_TYPES=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,text/plain,text/markdown,text/csv

SENTRY_DSN=
LOG_LEVEL=INFO
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_DEMO_MODE=true

